{
  "name": "Form 1040 E-File Extension",
  "return_type": "1040",
  "version": "1.0",
  "description": "20-stage process with screen verification for Form 1040 (Individual)",
  "static_inputs": {},
  "stages": [
    {
      "id": 1,
      "name": "click_efile_menu",
      "description": "Click E-File in the top menu bar",
      "verify_screen": "1040/01_basic_information.png",
      "action": "click",
      "target": { "image": "common/efile_menu.png" },
      "verify_next": "1040/02_efile_center.png"
    },
    {
      "id": 2,
      "name": "click_submit_electronic_filing",
      "description": "Select Submit Electronic Filing Return in popup",
      "verify_screen": "1040/02_efile_center.png",
      "action": "click",
      "target": { "image": "common/submit_electronic_filing.png" },
      "verify_next": "1040/03_file_extension.png"
    },
    {
      "id": 3,
      "name": "select_file_extension_and_continue",
      "description": "Select File Extension option and click Continue",
      "verify_screen": "1040/03_file_extension.png",
      "action": "multi",
      "actions": [
        {
          "action": "click",
          "target": { "image": "common/file_extension_option_unchecked.png" },
          "wait_after": 0.5
        },
        {
          "action": "click",
          "target": { "image": "common/continue_blue.png" },
          "wait_after": 0
        }
      ],
      "verify_next": "1040/04_federal_extension.png"
    },
    {
      "id": 4,
      "name": "click_yes_federal_extension",
      "description": "Click Yes on Federal Extension screen",
      "verify_screen": "1040/04_federal_extension.png",
      "action": "click",
      "target": { "image": "common/yes_green.png" },
      "verify_next": "1040/05_application_for_automatic_extension.png"
    },
    {
      "id": 5,
      "name": "click_complete_form_4868",
      "description": "Click Complete Form 4868 button",
      "verify_screen": "1040/05_application_for_automatic_extension.png",
      "action": "click",
      "target": { "image": "1040/complete_form_4868_green.png" },
      "verify_next": "1040/06_personal_data.png"
    },
    {
      "id": 6,
      "name": "click_continue_personal_data",
      "description": "Continue on Personal Data screen",
      "verify_screen": "1040/06_personal_data.png",
      "action": "click",
      "target": { "image": "common/continue_blue.png" },
      "verify_next": "1040/07_spouse.png"
    },
    {
      "id": 7,
      "name": "click_continue_spouse",
      "description": "Continue on Spouse screen",
      "verify_screen": "1040/07_spouse.png",
      "action": "click",
      "target": { "image": "common/continue_blue.png" },
      "verify_next": "1040/08_address.png"
    },
    {
      "id": 8,
      "name": "click_continue_address",
      "description": "Continue on Address screen",
      "verify_screen": "1040/08_address.png",
      "action": "click",
      "target": { "image": "common/continue_blue.png" },
      "verify_next": "1040/09_tax_liability.png"
    },
    {
      "id": 9,
      "name": "click_continue_tax_liability",
      "description": "Continue on Tax Liability screen",
      "verify_screen": "1040/09_tax_liability.png",
      "action": "click",
      "target": { "image": "common/continue_blue.png" },
      "verify_next": "1040/10_payment_amount.png"
    },
    {
      "id": 10,
      "name": "click_continue_payment_amount",
      "description": "Continue on Payment Amount screen",
      "verify_screen": "1040/10_payment_amount.png",
      "action": "click",
      "target": { "image": "common/continue_blue.png" },
      "verify_next": "1040/11_filing.png"
    },
    {
      "id": 11,
      "name": "click_efile_green",
      "description": "Click green E-File button on Filing screen",
      "verify_screen": "1040/11_filing.png",
      "action": "click",
      "target": { "image": "1040/efile_green.png" },
      "wait_after": 3.0
    },
    {
      "id": 12,
      "name": "handle_post_efile",
      "description": "Check if Acknowledgement appeared; if not (Wizard/other), bail out to Client Manager",
      "action": "conditional",
      "condition": {
        "type": "element_visible",
        "image": "1040/acknowledgement_header.png"
      },
      "if_true": "continue",
      "if_false": {
        "action": "click",
        "description": "Click Clients button to return (Wizard/unexpected screen)",
        "target": { "image": "common/clients_button.png" }
      }
    },
    {
      "id": 13,
      "name": "click_continue_acknowledgement",
      "description": "Continue on Acknowledgement screen",
      "verify_screen": "1040/12_acknowledgement.png",
      "action": "click",
      "target": { "image": "common/continue_blue.png" },
      "verify_next": "1040/13_consent_to_disclosure.png"
    },
    {
      "id": 14,
      "name": "click_agree_consent",
      "description": "Click Agree on Consent to Disclosure screen",
      "verify_screen": "1040/13_consent_to_disclosure.png",
      "action": "click",
      "target": { "image": "1040/agree_green.png" },
      "verify_next": "1040/14_alerts.png"
    },
    {
      "id": 15,
      "name": "click_start_alerts",
      "description": "Click Start Alerts button on Review Alerts screen",
      "verify_screen": "1040/14_alerts.png",
      "action": "click",
      "target": { "image": "1040/start_alerts_green.png" },
      "wait_after": 2.0
    },
    {
      "id": 16,
      "name": "handle_third_party_designee",
      "description": "If Third-Party Designee screen appears, fill 3 fields and re-run alerts; otherwise continue",
      "action": "conditional",
      "condition": {
        "type": "element_visible",
        "image": "1040/third_party_designee.png"
      },
      "if_true": {
        "action": "multi",
        "actions": [
          {
            "action": "click",
            "target": { "image": "1040/label_designee_name.png", "offset_y": 25 },
            "wait_after": 0.3
          },
          {
            "action": "type",
            "text_value": "TATIANA MOROZ",
            "clear_first": true,
            "wait_after": 0.5
          },
          {
            "action": "click",
            "target": { "image": "1040/label_designee_phone.png", "offset_y": 25 },
            "wait_after": 0.3
          },
          {
            "action": "type",
            "text_value": "(847)850-0085",
            "clear_first": true,
            "wait_after": 0.5
          },
          {
            "action": "click",
            "target": { "image": "1040/label_designee_pin.png", "offset_y": 25 },
            "wait_after": 0.3
          },
          {
            "action": "type",
            "text_value": "12345",
            "clear_first": true,
            "wait_after": 0.5
          },
          {
            "action": "click",
            "target": { "image": "common/continue_blue.png" },
            "wait_after": 2.0
          },
          {
            "action": "click",
            "target": { "image": "1040/start_alerts_short.png" },
            "wait_after": 2.0
          }
        ]
      },
      "if_false": "continue"
    },
    {
      "id": 17,
      "name": "handle_alerts_result",
      "description": "Check if Passed Alerts or error - different actions",
      "action": "conditional",
      "condition": {
        "type": "element_visible",
        "image": "common/passed_alerts.png"
      },
      "if_true": {
        "action": "click",
        "target": { "image": "common/continue_blue.png" },
        "verify_next": "1040/16_submit.png"
      },
      "if_false": {
        "action": "click",
        "description": "Click Clients button to return (Error case)",
        "target": { "image": "common/clients_button.png" }
      }
    },
    {
      "id": 18,
      "name": "click_submit_efile",
      "description": "Click Submit E-File button (no retry - dangerous!)",
      "verify_screen": "1040/16_submit.png",
      "action": "click",
      "target": { "image": "common/submit_efile.png" },
      "verify_next": "1040/17_successful.png",
      "no_retry": true,
      "verify_timeout": 30.0
    },
    {
      "id": 19,
      "name": "handle_submit_result",
      "description": "Check if E-File Successful or error - safeguard",
      "action": "conditional",
      "condition": {
        "type": "element_visible",
        "image": "1040/successful.png"
      },
      "if_true": {
        "action": "click",
        "target": { "image": "common/continue_blue.png" },
        "verify_next": "1040/18_complete.png"
      },
      "if_false": {
        "action": "click",
        "description": "Click Clients button to return (Error case)",
        "target": { "image": "common/clients_button.png" }
      }
    },
    {
      "id": 20,
      "name": "click_clients_complete",
      "description": "Click Clients button on Filing Complete screen to return to Client Manager",
      "verify_screen": "1040/18_complete.png",
      "action": "click",
      "target": { "image": "common/clients_button.png" },
      "verify_next": "1040/19_base.png"
    }
  ]
}
